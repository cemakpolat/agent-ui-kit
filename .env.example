# HARI Development Environment Configuration

# Transport Type
# Options: mock | websocket | sse | mcp
# Default: mock (in-process simulation, no servers needed)
VITE_TRANSPORT=mock

# WebSocket Transport (optional, only if using VITE_TRANSPORT=websocket)
# Default: ws://localhost:3001
VITE_WEBSOCKET_URL=ws://localhost:3001

# Server-Sent Events Transport (optional, only if using VITE_TRANSPORT=sse)
# Default: http://localhost:3002
VITE_SSE_URL=http://localhost:3002

# MCP Transport (optional, only if using VITE_TRANSPORT=mcp)
# Default: ws://localhost:3003
VITE_MCP_URL=ws://localhost:3003

# Ollama Configuration (for dev servers)
# These are set automatically in docker-compose.yml
# If running servers outside Docker, configure these:
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=orca-mini

# Development Server Ports
# These match docker-compose.yml services
DEV_WS_SERVER_PORT=3001
DEV_SSE_SERVER_PORT=3002
DEV_MCP_SERVER_PORT=3003
OLLAMA_PORT=11434
